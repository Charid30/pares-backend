# Configuration Serveur
NODE_ENV=development
PORT=5000

# Configuration Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pares_db
DB_USER=root
DB_PASSWORD=''

# Configuration JWT — générer: node -e "require('crypto').randomBytes(64).toString('hex')"
# Ne JAMAIS mettre la vraie valeur de production ici (ce fichier est un modèle destiné à être partagé/commité).
JWT_SECRET=remplacer_par_une_valeur_generee_aleatoirement
JWT_EXPIRES_IN=1h

# Configuration Application
APP_NAME=PARES

# URL du backend (utilisée dans les liens des emails)
# Développement local :
APP_URL=http://localhost:5000
# Production (nom de domaine) :
PROD_APP_URL=https://portail.sonabhy.bf

# URL du frontend (utilisée dans les liens des emails + origine CORS autorisée)
# Développement local :
FRONTEND_URL=http://localhost:4200
# Production (nom de domaine) :
PROD_FRONTEND_URL=https://portail.sonabhy.bf

# =====================================================
# Antivirus ClamAV (scan des fichiers uploadés)
# =====================================================
# AV_SCAN_ENABLED=true       → activer le scan (true par défaut)
# AV_STRICT=true             → rejeter si ClamAV indisponible (recommandé en prod)
# AV_HOST / AV_PORT          → adresse du daemon clamd
#
# Installation ClamAV :
#   Linux  : sudo apt-get install clamav clamav-daemon && sudo freshclam
#   macOS  : brew install clamav
#   Windows: https://www.clamav.net/downloads
# =====================================================
AV_SCAN_ENABLED=true
AV_STRICT=false
AV_HOST=127.0.0.1
AV_PORT=3310
# AV_CLAMSCAN_PATH=/usr/bin/clamscan
# AV_CLAMDSCAN_PATH=/usr/bin/clamdscan

# =====================================================
# Configuration Email (SMTP)
# =====================================================
# En développement, si ces variables ne sont pas définies,
# les emails seront loggés en console uniquement.

# Pour la production, vous pouvez utiliser:
# - Gmail (nécessite App Password): smtp.gmail.com, port 587 et dans notre cas c'est ce que j'ai utilisé
# - Donc n'oubliez pas de changer celà car je vais reset tout cela qui est actuellement lié à mon compte gmail
# - Outlook: smtp.office365.com, port 587
# - SendGrid: smtp.sendgrid.net, port 587
# - Mailgun: smtp.mailgun.org, port 587
# - Votre propre serveur SMTP
# =====================================================

# Serveur SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Authentification SMTP
# SMTP_USER=votre.email@gmail.com
# SMTP_PASS=VOTRE_APP_PASSWORD_GMAIL

# Expéditeur par défaut
# SMTP_FROM_NAME=PARES
# SMTP_FROM_EMAIL=votre.email@gmail.com

# =====================================================
# Exemple de configuration Gmail:
# =====================================================
# 1. Activer l'authentification à 2 facteurs sur votre compte Google
# 2. Générer un "Mot de passe d'application" sur https://myaccount.google.com/apppasswords
# 3. Utiliser ce mot de passe pour SMTP_PASS
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=votre_email@gmail.com
# SMTP_PASS=abcd efgh ijkl mnop

# =====================================================
# Resend (API email via HTTPS — recommandé si le SMTP
# sortant (587/465) est bloqué par le pare-feu réseau)
# =====================================================
# Si RESEND_API_KEY est défini, il est utilisé EN PRIORITÉ sur le SMTP ci-dessus.
# 1. Créer un compte sur https://resend.com (gratuit, 100 emails/jour)
# 2. Vérifier votre domaine (ex: sonabhy.bf) dans Resend, ou utiliser
#    onboarding@resend.dev pour tester (envoi limité à votre propre email)
# 3. Créer une clé API sur https://resend.com/api-keys
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@sonabhy.bf
